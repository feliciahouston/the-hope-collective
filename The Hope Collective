<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --gold: #C9A96E;
    --gold-light: #E8D5B0;
    --cream: #FAF7F2;
    --warm-white: #FFFDF9;
    --deep: #1A1410;
    --charcoal: #3D3530;
    --muted: #8C7B6E;
    --soft: #F0EAE0;
  }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--deep); overflow-x: hidden; }

  /* ANIMATIONS */
  @keyframes fadeDown { from { opacity:0; transform:translateY(-16px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @keyframes float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-10px);} }

  /* NAV */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    padding: 1.2rem 3rem;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(250,247,242,0.93);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(201,169,110,0.2);
    animation: fadeDown 0.8s ease both;
  }
  .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.55rem; font-weight: 300; letter-spacing: 0.04em; color: var(--deep); }
  .nav-logo span { color: var(--gold); font-style: italic; }
  .nav-links { display: flex; gap: 2.5rem; align-items: center; }
  .nav-links a { font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; color: var(--charcoal); transition: color 0.3s; }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta { background: var(--gold) !important; color: var(--deep) !important; padding: 0.55rem 1.3rem !important; border-radius: 2px; font-weight: 500 !important; }
  .nav-cta:hover { background: var(--deep) !important; color: var(--gold) !important; }

  /* HERO */
  .hero {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden; padding: 8rem 2rem 4rem;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(201,169,110,0.13) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(201,169,110,0.08) 0%, transparent 50%), var(--cream);
  }
  .hero-orb {
    position: absolute; top: 12%; right: 7%;
    width: 340px; height: 340px; opacity: 0.06;
    background: conic-gradient(from 0deg, var(--gold), transparent, var(--gold), transparent, var(--gold));
    border-radius: 50%; animation: spin 45s linear infinite;
  }
  .hero-orb2 {
    position: absolute; bottom: 8%; left: 4%;
    width: 200px; height: 200px; opacity: 0.05;
    background: conic-gradient(from 90deg, var(--gold), transparent, var(--gold));
    border-radius: 50%; animation: spin 28s linear infinite reverse;
  }
  .hero-content { text-align: center; max-width: 800px; position: relative; z-index: 2; }
  .hero-eyebrow {
    font-size: 0.73rem; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1.6rem;
    animation: fadeUp 1s ease 0.2s both;
  }
  .hero-eyebrow::before, .hero-eyebrow::after { content: '——'; margin: 0 0.6rem; opacity: 0.45; }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 5.8rem);
    font-weight: 300; line-height: 1.1; color: var(--deep);
    animation: fadeUp 1s ease 0.4s both;
  }
  .hero h1 em { font-style: italic; color: var(--gold); }
  .hero-sub {
    margin: 2rem auto 0; font-size: 1.05rem; line-height: 1.85;
    color: var(--muted); max-width: 530px;
    animation: fadeUp 1s ease 0.6s both;
  }
  .hero-actions {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    margin-top: 2.8rem; animation: fadeUp 1s ease 0.8s both;
  }
  .btn-primary {
    background: var(--gold); color: var(--deep);
    padding: 1rem 2.5rem; border: none; border-radius: 2px;
    font-family: 'DM Sans', sans-serif; font-size: 0.82rem;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 500;
    cursor: pointer; transition: all 0.3s; text-decoration: none; display: inline-block;
  }
  .btn-primary:hover { background: var(--deep); color: var(--gold); transform: translateY(-2px); box-shadow: 0 10px 30px rgba(201,169,110,0.25); }
  .btn-secondary {
    background: transparent; color: var(--charcoal);
    padding: 1rem 2.5rem; border: 1px solid rgba(61,53,48,0.28); border-radius: 2px;
    font-family: 'DM Sans', sans-serif; font-size: 0.82rem;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 400;
    cursor: pointer; transition: all 0.3s; text-decoration: none; display: inline-block;
  }
  .btn-secondary:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }
  .hero-trust {
    margin-top: 3rem; font-size: 0.8rem; color: var(--muted); letter-spacing: 0.05em;
    animation: fadeUp 1s ease 1s both;
  }
  .hero-trust strong { color: var(--gold); }

  /* MARQUEE */
  .marquee-wrap { background: var(--deep); padding: 1.6rem 0; overflow: hidden; }
  .marquee-track { display: flex; gap: 0; animation: marquee 35s linear infinite; white-space: nowrap; }
  .marquee-track span {
    font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; font-style: italic;
    color: var(--gold-light); padding: 0 3rem; flex-shrink: 0;
  }
  .marquee-track .sep { color: var(--gold); font-size: 0.4rem; vertical-align: middle; }

  /* SECTIONS */
  .section { padding: 6rem 3rem; }
  .section-label { font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.8rem; text-align: center; }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem); font-weight: 300;
    text-align: center; line-height: 1.2; color: var(--deep); margin-bottom: 1rem;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .section-sub { text-align: center; color: var(--muted); font-size: 0.97rem; line-height: 1.85; max-width: 500px; margin: 0 auto 4rem; }

  /* FEATURES */
  .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.8rem; max-width: 1100px; margin: 0 auto; }
  .feature-card {
    background: var(--warm-white); border: 1px solid rgba(201,169,110,0.18);
    padding: 2.4rem 2rem; border-radius: 4px;
    transition: all 0.4s; position: relative; overflow: hidden;
  }
  .feature-card::after {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    transform: scaleX(0); transition: transform 0.4s;
  }
  .feature-card:hover { transform: translateY(-6px); box-shadow: 0 24px 60px rgba(26,20,16,0.08); }
  .feature-card:hover::after { transform: scaleX(1); }
  .feature-icon { font-size: 2.2rem; margin-bottom: 1.2rem; animation: float 4s ease-in-out infinite; }
  .feature-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; font-weight: 400; margin-bottom: 0.6rem; color: var(--deep); }
  .feature-card p { color: var(--muted); font-size: 0.9rem; line-height: 1.75; }

  /* SAMPLES */
  .samples-section { background: var(--soft); }
  .samples-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 1.5rem; max-width: 1100px; margin: 0 auto; }
  .sample-card {
    background: var(--warm-white); border-radius: 4px; padding: 2.4rem;
    border-left: 3px solid var(--gold);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .sample-card:hover { transform: translateY(-4px); box-shadow: 0 16px 45px rgba(26,20,16,0.07); }
  .sample-type { font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
  .sample-card blockquote {
    font-family: 'Cormorant Garamond', serif; font-size: 1.2rem;
    font-style: italic; line-height: 1.7; color: var(--charcoal); margin-bottom: 1.2rem;
  }
  .sample-card cite { font-size: 0.78rem; color: var(--muted); letter-spacing: 0.06em; }

  /* PRICING */
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 1000px; margin: 0 auto; }
  .pricing-card {
    background: var(--warm-white); border: 1px solid rgba(201,169,110,0.2);
    border-radius: 4px; padding: 2.8rem 2.2rem;
    transition: all 0.4s; position: relative;
  }
  .pricing-card.featured {
    background: var(--deep); border-color: var(--gold);
    transform: scale(1.03);
    box-shadow: 0 30px 70px rgba(26,20,16,0.18);
  }
  .pricing-card:hover:not(.featured) { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(26,20,16,0.08); }
  .pricing-badge {
    position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
    background: var(--gold); color: var(--deep);
    font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase;
    padding: 0.35rem 1.1rem; border-radius: 20px; font-weight: 500; white-space: nowrap;
  }
  .pricing-tier { font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.8rem; }
  .pricing-name { font-family: 'Cormorant Garamond', serif; font-size: 1.9rem; font-weight: 300; margin-bottom: 0.5rem; }
  .pricing-card.featured .pricing-name { color: var(--warm-white); }
  .pricing-price { margin: 1.4rem 0; }
  .pricing-price .amount { font-family: 'Cormorant Garamond', serif; font-size: 3.2rem; font-weight: 300; color: var(--gold); }
  .pricing-price .period { font-size: 0.85rem; color: var(--muted); margin-left: 4px; }
  .pricing-card.featured .pricing-price .period { color: rgba(250,247,242,0.55); }
  .pricing-desc { font-size: 0.88rem; line-height: 1.7; color: var(--muted); margin-bottom: 1.8rem; }
  .pricing-card.featured .pricing-desc { color: rgba(250,247,242,0.6); }
  .pricing-features { list-style: none; margin-bottom: 2.2rem; }
  .pricing-features li { font-size: 0.88rem; color: var(--charcoal); padding: 0.5rem 0; border-bottom: 1px solid rgba(201,169,110,0.1); display: flex; align-items: center; gap: 0.7rem; }
  .pricing-card.featured .pricing-features li { color: rgba(250,247,242,0.8); border-color: rgba(201,169,110,0.15); }
  .pricing-features li::before { content: '✦'; color: var(--gold); font-size: 0.6rem; flex-shrink: 0; }
  .pricing-btn {
    width: 100%; padding: 0.95rem; border: none; border-radius: 2px;
    font-family: 'DM Sans', sans-serif; font-size: 0.8rem; letter-spacing: 0.12em;
    text-transform: uppercase; font-weight: 500; cursor: pointer; transition: all 0.3s;
  }
  .pricing-btn-outline { background: transparent; border: 1px solid rgba(201,169,110,0.4) !important; color: var(--gold); }
  .pricing-btn-outline:hover { background: var(--gold); color: var(--deep); }
  .pricing-btn-fill { background: var(--gold); color: var(--deep); }
  .pricing-btn-fill:hover { background: var(--gold-light); }
  .pricing-btn-dark { background: var(--deep); color: var(--gold); border: 1px solid transparent !important; }
  .pricing-btn-dark:hover { background: var(--charcoal); }

  /* TESTIMONIALS */
  .testimonials-section { background: var(--deep); }
  .testimonials-section .section-title { color: var(--gold-light); }
  .testimonials-section .section-label { color: rgba(201,169,110,0.7); }
  .testimonials-section .section-sub { color: rgba(250,247,242,0.45); }
  .testimonials-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 1.5rem; max-width: 1000px; margin: 0 auto; }
  .testimonial-card {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(201,169,110,0.15);
    border-radius: 4px; padding: 2.2rem; transition: all 0.3s;
  }
  .testimonial-card:hover { background: rgba(255,255,255,0.07); transform: translateY(-4px); }
  .testimonial-stars { color: var(--gold); font-size: 0.85rem; margin-bottom: 1rem; letter-spacing: 0.1em; }
  .testimonial-card p { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-style: italic; line-height: 1.75; color: rgba(250,247,242,0.8); margin-bottom: 1.4rem; }
  .testimonial-author { font-size: 0.78rem; color: var(--gold); letter-spacing: 0.1em; text-transform: uppercase; }

  /* CTA BANNER */
  .cta-section {
    padding: 6rem 3rem; text-align: center;
    background: linear-gradient(135deg, var(--cream) 0%, var(--soft) 100%);
    position: relative; overflow: hidden;
  }
  .cta-section::before {
    content: ''; position: absolute; top: -50%; left: -20%;
    width: 60%; height: 200%;
    background: radial-gradient(ellipse, rgba(201,169,110,0.1) 0%, transparent 70%);
  }
  .cta-section .section-title { margin-bottom: 1rem; }
  .cta-section p { color: var(--muted); font-size: 1rem; line-height: 1.8; max-width: 480px; margin: 0 auto 2.5rem; }

  /* FOOTER */
  footer {
    background: var(--deep); padding: 3rem;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1.5rem;
    border-top: 1px solid rgba(201,169,110,0.15);
  }
  .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 300; color: var(--gold-light); }
  .footer-logo span { font-style: italic; color: var(--gold); }
  .footer-links { display: flex; gap: 2rem; }
  .footer-links a { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; color: rgba(250,247,242,0.4); transition: color 0.3s; }
  .footer-links a:hover { color: var(--gold); }
  .footer-copy { font-size: 0.78rem; color: rgba(250,247,242,0.25); }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .section { padding: 4rem 1.5rem; }
    .pricing-card.featured { transform: scale(1); }
    footer { flex-direction: column; text-align: center; padding: 2rem 1.5rem; }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
</head>
